{
  "name": "xrea/php-agent",
  "description": "PHP-based AI agent for XREA hosting environment",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-phar": "*"
  },
  "require-dev": {
    "pestphp/pest": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Xrea\\Agent\\": "src/"
    }
  },
  "bin": [
    "bin/agent"
  ],
  "scripts": {
    "build": "php -d phar.readonly=0 build.php",
    "serve": "php -S 0.0.0.0:8080 -t public",
    "test": "pest",
    "test:unit": "pest tests/Unit"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    },
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "license": "MIT"
}
